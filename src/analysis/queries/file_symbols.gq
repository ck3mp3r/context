query file_symbols($path: String)
  @description("All symbols defined in a specific file")
  @instruction("Use to get an overview of a single file's contents")
{
  match {
    $f: File { path: $path }
    $s: Symbol
    $f fileContains $s
  }
  return { $s.name, $s.kind, $s.visibility, $s.start_line, $s.end_line, $s.signature, $s.entry_type }
  order { $s.start_line asc }
}
